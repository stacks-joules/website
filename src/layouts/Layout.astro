---
import '../styles/fonts.css';
import '../styles/global.css';
import { siteMetadata } from '../data/site';
import { HeaderIsland } from '../components/layout/HeaderIsland';
import { Navigation } from '../components/layout/Navigation';
import { ContactSection } from '../components/sections/ContactSection';
import { Footer } from '../components/layout/Footer';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = siteMetadata.title,
  description = siteMetadata.description,
} = Astro.props;

// Canonical, per-page absolute URL (from astro.config `site`). Drives both the
// canonical link and og:url so social cards point at the page, not the root.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Stop iOS from auto-styling phone numbers as blue links -->
    <meta name="format-detection" content="telephone=no" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons: SVG (theme-adaptive) for modern browsers, .ico fallback for
         Safari/older browsers and the automatic /favicon.ico request. -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={siteMetadata.ogType} />
    <meta property="og:image" content={siteMetadata.ogImage} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={siteMetadata.twitterUsername} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Preload the fonts that render above the fold (prevents FOUT/shift) -->
    <link
      rel="preload"
      href="/fonts/MontaguSlab_120pt-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/inter-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/inter-latin-600-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!-- Client-side routing: swap pages without a full reload, so links
         don't flash white and fonts/state persist between navigations. -->
    <ClientRouter />

    <!-- Global color roll: pink/sky/yellow on a worldwide 30-second UTC clock.
         Runs inline before first paint to avoid FOUC. No backend, no storage:
         the color is a pure function of time, so every visitor on Earth sees
         the same color in the same 30s slot, and it never repeats
         back-to-back. The slot is short enough that navigating between pages
         usually lands in a new slot, so the accent visibly rolls as you browse
         (the color is recomputed on each navigation). Static fallback (no JS /
         crawlers) is pink via :root. QA override: ?color=pink|sky|yellow
         (blue/cyan alias to sky), sticky for the tab via sessionStorage;
         ?color=clock clears it. -->
    <script is:inline>
      (function () {
        var COLORS = ['pink', 'sky', 'yellow'];
        var SLOT_MS = 30 * 1000;

        // mulberry32 PRNG — deterministic for a given seed on every client
        function rng(seed) {
          return function () {
            seed |= 0;
            seed = (seed + 0x6d2b79f5) | 0;
            var t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
            t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
            return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
          };
        }

        // Seeded Fisher-Yates shuffle of the 3 colors for a block of 3 slots
        function basePerm(block) {
          var a = COLORS.slice();
          var r = rng(block);
          for (var i = a.length - 1; i > 0; i--) {
            var j = Math.floor(r() * (i + 1));
            var t = a[i];
            a[i] = a[j];
            a[j] = t;
          }
          return a;
        }

        // Color for a slot. Within a block the perm guarantees no repeats;
        // at block boundaries, if our first color equals the previous
        // block's last, swap our first two. The swap never touches the last
        // element, so "previous block's last" is always basePerm(b-1)[2] —
        // closed-form, no recursion.
        function themeForSlot(slot) {
          var block = Math.floor(slot / 3);
          var p = basePerm(block);
          if (p[0] === basePerm(block - 1)[2]) {
            var t = p[0];
            p[0] = p[1];
            p[1] = t;
          }
          return p[((slot % 3) + 3) % 3];
        }

        function applyTheme() {
        var theme = null;
        try {
          var q = new URLSearchParams(location.search).get('color');
          var alias = { blue: 'sky', cyan: 'sky' };
          if (q) q = alias[q] || q;
          if (q === 'clock') {
            sessionStorage.removeItem('sjColorOverride');
          } else if (q && COLORS.indexOf(q) > -1) {
            sessionStorage.setItem('sjColorOverride', q);
            theme = q;
          } else {
            var stored = sessionStorage.getItem('sjColorOverride');
            if (stored && COLORS.indexOf(stored) > -1) theme = stored;
          }
        } catch (e) {
          /* sessionStorage unavailable — clock still works */
        }

        if (!theme) theme = themeForSlot(Math.floor(Date.now() / SLOT_MS));

        var el = document.documentElement;
        el.classList.remove('theme-pink', 'theme-sky', 'theme-yellow');
        el.classList.add('theme-' + theme);
        el.dataset.theme = theme;
        }
        applyTheme();
        // Re-apply after each client-side navigation (ClientRouter swaps the
        // document, which would otherwise drop the runtime theme class).
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
  </head>
  <body>
    <HeaderIsland client:load />
    <Navigation client:load />
    <main>
      <slot />
    </main>
    <ContactSection client:visible />
    <Footer />
  </body>
</html>
