---
import Layout from '../layouts/Layout.astro';
import { CardContainer } from '../components/blocks/card-section/CardContainer';
import { Card } from '../components/blocks/card-section/Card';
import { Infographic } from '../components/sections/Infographic';
import { EmployerGrid } from '../components/sections/EmployerGrid';
import { NewsletterSignup } from '../components/sections/NewsletterSignup';
import { Wallpaper } from '../components/common/Wallpaper';
import { ImagePanel } from '../components/blocks/panels/ImagePanel';
import { TextPanel } from '../components/blocks/panels/TextPanel';
import { Block } from '../components/blocks/block/Block';
import { donationLink } from '../data/site';

const StudentImage = '/images/student-photo-1.webp';
const TeamImage = '/images/home-mission.webp';
const WiringImage = '/images/wiring-curriculum.webp';
const DonateImage = '/images/home-donate.webp';
const CardOne = '/images/card-1.webp';
const CardTwo = '/images/home-employer.webp';
const CardThree = '/images/home-howitworks-3.webp';
const CurriculumImage1 = '/images/curriculum-image-1.webp';
const CurriculumImage2 = '/images/home-handson.webp';
const CurriculumImage3 = '/images/curriculum-image-3.webp';
const CurriculumImage4 = '/images/home-howitworks-2.webp';
const LightCurriculumImage = '/images/home-howitworks-1.webp';

const pathwayCards = [
  {
    headerText: 'For Learners',
    border: true,
    imageSrc: CardOne,
    imageAlt: 'A Stacks+Joules trainee learning building automation.',
    content:
      "Train for a career in Building Automation. No tuition. No prior experience required. Twelve weeks of hands-on training, three industry certifications, a paid internship, and a clear path to full-time employment.",
    buttonText: 'TRAIN WITH US',
    buttonLink: '#contact',
  },
  {
    headerText: 'For Employers',
    border: true,
    imageSrc: CardTwo,
    imageAlt: 'A Stacks+Joules graduate working on a building automation panel.',
    content:
      "Hire pre-trained BAS talent. Our graduates arrive certified in EPA 608, Niagara, and LCA. They know wiring, controllers, safety, and documentation before day one.",
    buttonText: 'HIRE OUR GRADUATES',
    buttonLink: '#contact',
  },
];

const pathwayStepCards = [
  {
    imageSrc: LightCurriculumImage,
    imageAlt: 'Foundational training in BAS concepts.',
    contentTitle: '1. Foundational Training',
    content:
      'Twelve weeks of fundamentals: electricity, HVAC, networking, controls logic. Designed for people entering the field, not for people already in it.',
  },
  {
    imageSrc: CurriculumImage4,
    imageAlt: 'Paid internship at a partner organization.',
    contentTitle: '2. Paid Internship',
    content:
      'A paid internship at one of our hiring partners. You work on real systems. Employers see how you operate. You see if the work is for you.',
  },
  {
    imageSrc: CardThree,
    imageAlt: 'A Stacks+Joules graduate shaking hands with an employer.',
    contentTitle: '3. Full-Time Employment',
    content:
      "A clear path to full-time work with our employer network. Graduates move into roles like BAS technician, controls installer, or junior programmer, with senior techs who already know the curriculum they came through.",
  },
];

const curriculumCards = [
  {
    contentTitle: 'No Prior Experience Required',
    imageSrc: CurriculumImage1,
    imageAlt: 'Trainees learning fundamentals.',
    content:
      'We start with fundamentals: electricity, HVAC principles, networking basics, and controls logic. The curriculum is designed for learners entering the field, not just those already in it.',
  },
  {
    contentTitle: 'Hands-On with Real Equipment',
    imageSrc: CurriculumImage2,
    imageAlt: 'Hands-on training with controllers and sensors.',
    content:
      'Training includes work with actual controllers, sensors, dampers, and building management systems. Learners troubleshoot live systems - not simulations - preparing them for the realities of the job site.',
  },
  {
    contentTitle: 'Workplace Skills',
    imageSrc: CurriculumImage3,
    imageAlt: 'Safety and documentation training.',
    content:
      'Beyond technical skills, we emphasize workplace safety protocols, proper documentation practices, and clear communication - skills that reduce risk and improve project outcomes.',
  },
];

const infographicCards = [
  { title: 'Graduates Placed', number: '143', symbol: '' },
  { title: 'Placement Rate', number: '89', symbol: '%' },
  { title: 'Starting Pay', number: '$24–27', symbol: '/hr' },
  { title: 'Employer Partners', number: '20', symbol: '' },
];

const employers = [
  'Alberio',
  'Automated Logic',
  'Bosch',
  'Climatec',
  'ConEd',
  'Distech Controls',
  'Distinctive Windows',
  'Dual Fuel',
  'Johnson Controls',
  'Mr Air NYC',
  'RGSB',
  'Richards Heating & Plumbing',
  'Richmar Controls & Service Company',
  'SB Building Solutions',
  'Soulful Synergy',
  'Stratco Property Group',
  'T.M. Bier and Associates',
  'TEC Systems',
  'Trane',
  'Walker Hotels Tribeca',
];

const ahmedDescription =
  "Ahmed walked in with no building automation experience. TEC Systems hired him three months after graduation. Three years later, he was a Senior Commissioning Technician. Now he trains the next Stacks+Joules cohort coming through TEC.\n\n\"With Stacks+Joules, we can confidently bid on any project. We know where to find talent.\"\n- Colin Gumbs, COO, TEC Systems";
---

<Layout>
  <!-- 1. Hero -->
  <Block variation="dark">
    <TextPanel
      title="Your career in Building Automation starts here."
      description="Twelve weeks of hands-on training. Three industry certifications - EPA 608, Niagara, and LCA. A paid internship and a clear path into Building Automation. No prior experience required."
      buttonText="TRAIN WITH US"
      buttonLink="#contact"
    />
    <ImagePanel
      imageSrc={StudentImage}
      imageAlt="A Stacks+Joules trainee in branded cap."
      dropShadow
      priority
    />
  </Block>

  <!-- 2. Dual pathway cards (For Learners / For Employers) -->
  <Block variation="light" singleColumn>
    <CardContainer>
      {pathwayCards.map(({ headerText, ...rest }) => (
        <Card key={headerText} headerText={headerText} {...rest} />
      ))}
    </CardContainer>
  </Block>

  <!-- 3. Mission -->
  <Block variation="dark">
    <ImagePanel
      imageSrc={TeamImage}
      imageAlt="The Stacks+Joules team."
      dropShadow
    />
    <TextPanel
      title="Bridging the tech opportunity gap."
      description="BAS/controls roles are facing a documented skilled labor shortage, especially in HVAC controls and systems integration. Every commercial building runs on automation that needs people to install, maintain, and upgrade it. As buildings get smarter and experienced techs retire, employers need a stronger talent pipeline. Stacks+Joules trains overlooked populations for those jobs. We don't run a classroom - we run a pipeline from no prior experience to a paid internship by week thirteen."
    />
  </Block>

  <!-- 4. Pathway diagram (How It Works) -->
  <Block variation="light" paddingY="0px" singleColumn>
    <CardContainer
      title="How It Works"
      description="Three stages. From Training to Internship to Full-Time Employment. Each one designed with our hiring partners. Every step puts you closer to a real job site."
    >
      {pathwayStepCards.map(({ contentTitle, ...rest }) => (
        <Card key={contentTitle} contentTitle={contentTitle} {...rest} />
      ))}
    </CardContainer>
  </Block>

  <!-- 5. Impact stats -->
  <Infographic title="Our Impact" cards={infographicCards} />

  <!-- 6. Curriculum -->
  <Block variation="light" paddingY="0px" singleColumn>
    <CardContainer
      title="Training Built on Real Systems"
      description="We train on the same equipment our graduates use on the job. Same tools. Same terminology. Same wiring. By graduation, you've already done the work."
    >
      {curriculumCards.map(({ contentTitle, ...rest }) => (
        <Card key={contentTitle} contentTitle={contentTitle} {...rest} />
      ))}
    </CardContainer>
  </Block>

  <!-- 7. Case study / Ahmed -->
  <Block variation="dark">
    <ImagePanel
      imageSrc={WiringImage}
      imageAlt="A Stacks+Joules graduate working on a real building automation panel."
      dropShadow
    />
    <TextPanel
      caption="Case Study"
      smallTitle="From trainee to trainer in three years."
      description={ahmedDescription}
    />
  </Block>

  <!-- 8. Employer wordmark grid -->
  <EmployerGrid
    title="Where Our Graduates Work"
    description="Our graduates have been placed with 20 leading NYC building automation companies:"
    employers={employers}
  />

  <!-- 9. Donate CTA -->
  <Block variation="dark">
    <TextPanel
      caption="Support Stacks+Joules"
      smallTitle="We're not just filling jobs. We're building a pipeline that feeds the entire ecosystem."
      description="Fund a trainee. A building runs better. A career begins. The pipeline grows. Every gift helps train the next graduate - and graduates come back to train the cohort after that."
      buttonText="DONATE"
      buttonLink={donationLink}
    />
    <ImagePanel
      imageSrc={DonateImage}
      imageAlt="A Stacks+Joules trainee at work."
      dropShadow
    />
  </Block>

  <!-- 10. Newsletter -->
  <NewsletterSignup client:visible />
  <Wallpaper />
</Layout>
