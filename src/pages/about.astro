---
import Layout from '../layouts/Layout.astro';
import { SectionHeader } from '../components/layout/SectionHeader';
import { Block } from '../components/blocks/block/Block';
import { TextPanel } from '../components/blocks/panels/TextPanel';
import { ImagePanel } from '../components/blocks/panels/ImagePanel';
import { CardContainer } from '../components/blocks/card-section/CardContainer';
import { Card } from '../components/blocks/card-section/Card';
import { Infographic } from '../components/sections/Infographic';
import { TransparencyBadges } from '../components/sections/TransparencyBadges';

const AboutImage = '/images/about-hero.webp';
const TeamImage = '/images/about-classroom.webp';
const ConwayImage = '/images/about-team.webp';
const LightCurriculumImage = '/images/about-howitworks-1.webp';
const CurriculumImage4 = '/images/about-howitworks-2.webp';
const CardThree = '/images/about-howitworks-3.webp';

const pathwayStepCards = [
  {
    imageSrc: LightCurriculumImage,
    imageAlt: 'Foundational training in BAS concepts.',
    contentTitle: '1. Foundational Training',
    content:
      'Fourteen weeks of fundamentals - electricity, HVAC, networking, and controls logic - built for people entering the field.',
  },
  {
    imageSrc: CurriculumImage4,
    imageAlt: 'Onboarding with a partner employer.',
    contentTitle: '2. Employer Onboarding',
    content:
      'Graduates onboard with a hiring partner, shadowing senior technicians on live systems.',
  },
  {
    imageSrc: CardThree,
    imageAlt: 'A Stacks+Joules graduate shaking hands with an employer.',
    contentTitle: '3. Full-Time Employment',
    content:
      'A clear path to full-time BAS roles within our employer network.',
  },
];

const infographicCards = [
  { title: 'Graduates Placed', number: '188', symbol: '' },
  { title: 'Placement Rate', number: '89', symbol: '%' },
  { title: 'Starting Pay', number: '$27', symbol: '/hr' },
  { title: 'Employer Partners', number: '20', symbol: '' },
];
---

<Layout
  title="About | Stacks+Joules"
  description="How Stacks+Joules turns overlooked talent into building automation professionals - 188 graduates placed, an 89% placement rate, and every instructor a graduate of the program."
>
  <SectionHeader>About</SectionHeader>

  <Block variation="dark">
    <ImagePanel
      imageSrc={AboutImage}
      imageAlt="Stacks+Joules logo and team."
      dropShadow
    />
    <TextPanel
      titleAs="h2"
      title="A pipeline, not a classroom."
      description="Stacks+Joules is a 501(c)(3) nonprofit that trains overlooked talent for careers in Building Automation - the technology that runs modern buildings. We don't run classes. We run a pipeline: fourteen weeks of training, onboarding with a partner employer, and a clear path to work alongside the companies that hire our graduates."
    />
  </Block>

  <Block variation="light" paddingY="0px" singleColumn>
    <CardContainer
      title="How It Works"
      description="From training to onboarding to full-time work - three stages, each designed with the employers who hire our graduates."
    >
      {pathwayStepCards.map(({ contentTitle, ...rest }) => (
        <Card key={contentTitle} contentTitle={contentTitle} {...rest} />
      ))}
    </CardContainer>
  </Block>

  <Block variation="dark">
    <TextPanel
      smallTitle="Not traditional classroom education."
      description="No lectures. No theory disconnected from practice. We train on the same controllers, sensors, and software our graduates will use the day they get hired. By the time you walk onto a job site, you've already done the work."
    />
    <ImagePanel
      imageSrc={TeamImage}
      imageAlt="The Stacks+Joules team and trainees."
      dropShadow
    />
  </Block>

  <Infographic title="Our Impact" cards={infographicCards} />

  <Block variation="dark">
    <ImagePanel
      imageSrc={ConwayImage}
      imageAlt="Co-founder J Michael Conway."
      dropShadow
    />
    <TextPanel
      smallTitle="Meet the team."
      description="Stacks+Joules was founded by educators and technologists who got tired of training programs that don't lead to jobs. Today, every instructor here came through the program first."
      buttonText="MEET THE TEAM"
      buttonLink="/team"
    />
  </Block>

  <a id="accountability"></a>
  <Block variation="light" singleColumn>
    <div class="accountability-block">
      <div class="accountability-block__eyebrow">Accountability</div>
      <h2 class="accountability-block__title">Transparency you can verify.</h2>
      <p class="accountability-block__body">
        Stacks+Joules is a 501(c)(3) nonprofit (EIN 82-2358571), rated by the
        leading independent nonprofit evaluators. Our Form 990 filings are
        public - and list our officers and board - so anyone can see exactly how
        the organization is run and funded. We don't publish a separate annual
        report; the 990 serves as our annual financial disclosure. Questions?
        Email <a href="mailto:info@stacksandjoules.org">info@stacksandjoules.org</a
        >.
      </p>
      <TransparencyBadges variant="full" />
      <p class="accountability-block__links">
        <a
          href="https://projects.propublica.org/nonprofits/organizations/822358571"
          target="_blank"
          rel="noopener">Form 990 filings (2017–2025)</a
        > · <a
          href="https://www.charitynavigator.org/ein/822358571"
          target="_blank"
          rel="noopener">Charity Navigator rating</a
        >
      </p>
    </div>
  </Block>
</Layout>

<style>
  .accountability-block {
    width: 100%;
    padding-top: 40px;
    padding-bottom: 40px;
    box-sizing: border-box;
  }

  /* Mobile gutters (parent Block strips its padding on mobile) */
  @media (max-width: 768px) {
    .accountability-block {
      padding: 40px 24px;
    }
  }
  .accountability-block__eyebrow {
    color: #000;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
  }
  .accountability-block__eyebrow::before {
    content: '';
    display: inline-block;
    width: 0.74em;
    height: 0.74em;
    vertical-align: 0.12em;
    background-color: currentColor;
    -webkit-mask: var(--arrow-mask) no-repeat center / contain;
    mask: var(--arrow-mask) no-repeat center / contain;
    margin-right: var(--arrow-gap);
  }
  .accountability-block__title {
    color: #000;
    font-family: 'Montagu Slab', serif;
    font-size: 38px;
    font-weight: 700;
    line-height: 110%;
    letter-spacing: -0.76px;
    text-transform: uppercase;
    margin: 0 0 16px;
  }
  .accountability-block__body {
    color: #333;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1.5;
    max-width: 720px;
    margin: 0 0 32px;
  }
  .accountability-block__links {
    color: #333;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    margin-top: 32px;
  }
  .accountability-block__links a {
    color: #000;
    text-decoration: underline;
  }
</style>
