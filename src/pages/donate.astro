---
import Layout from '../layouts/Layout.astro';
import { Block } from '../components/blocks/block/Block';
import { TextPanel } from '../components/blocks/panels/TextPanel';
import { ImagePanel } from '../components/blocks/panels/ImagePanel';
import { SectionHeader } from '../components/layout/SectionHeader';
import { Infographic } from '../components/sections/Infographic';
import { TransparencyBadges } from '../components/sections/TransparencyBadges';

import { donationLink } from '../data/site';

const donateImage = '/images/donate-image.webp';
const TeamImage = '/images/team.webp';

const infographicCards = [
  { title: 'Graduates Placed', number: '188', symbol: '' },
  { title: 'Placement Rate', number: '89', symbol: '%' },
  { title: 'Starting Pay', number: '$27', symbol: '/hr' },
  { title: 'Employer Partners', number: '20', symbol: '' },
];
---

<Layout
  title="Donate | Stacks+Joules"
  description="Donate to Stacks+Joules, a 501(c)(3) nonprofit. Your tax-deductible gift funds the equipment, certifications, and coaching that move overlooked talent into building automation careers."
>
  <SectionHeader>Make a donation</SectionHeader>

  <Block variation="dark">
    <ImagePanel
      imageSrc={TeamImage}
      imageAlt="Stacks+Joules trainees and team."
      dropShadow
    />
    <TextPanel
      caption="Support Stacks+Joules"
      smallTitle="We're not just filling jobs. We're building a pipeline that feeds the entire ecosystem."
      description="Your gift funds the equipment, certifications, and coaching that move overlooked talent into building automation careers. Every dollar helps train the next graduate - and graduates come back to train the cohort after that. Stacks+Joules is a 501(c)(3) nonprofit; your gift is tax-deductible. EIN 82-2358571."
    />
  </Block>

  <Infographic title="What Your Gift Funds" cards={infographicCards} />

  <Block variation="light" singleColumn>
    <div class="badge-strip">
      <div class="badge-strip__title">Accountability &amp; Transparency</div>
      <TransparencyBadges variant="full" />
    </div>
  </Block>

  <Block variation="dark">
    <ImagePanel imageSrc={donateImage} imageAlt="Donate" dropShadow />
    <TextPanel
      caption="Donate"
      smallTitle="Fund the next cohort."
      description="Donations are processed securely through our GoFundMe campaign. Stacks+Joules is a 501(c)(3) nonprofit; your gift is tax-deductible. EIN 82-2358571."
      buttonText="DONATE NOW"
      buttonLink={donationLink}
    />
  </Block>
</Layout>

<style>
  .badge-strip {
    width: 100%;
    padding-top: 40px;
    padding-bottom: 40px;
    box-sizing: border-box;
  }

  /* Mobile gutters (parent Block strips its padding on mobile) */
  @media (max-width: 768px) {
    .badge-strip {
      padding: 40px 24px;
    }
  }
  .badge-strip__title {
    color: #000;
    font-family: 'Inter', sans-serif;
    font-size: 24px;
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 32px;
  }
  .badge-strip__title::before {
    content: '';
    display: inline-block;
    width: 0.74em;
    height: 0.74em;
    vertical-align: 0.12em;
    background-color: currentColor;
    -webkit-mask: var(--arrow-mask) no-repeat center / contain;
    mask: var(--arrow-mask) no-repeat center / contain;
    margin-right: var(--arrow-gap);
  }
</style>
