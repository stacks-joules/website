---
import Layout from '../layouts/Layout.astro';
import { SectionHeader } from '../components/layout/SectionHeader';
import { Block } from '../components/blocks/block/Block';
import { TextPanel } from '../components/blocks/panels/TextPanel';
import { ImagePanel } from '../components/blocks/panels/ImagePanel';
import { CardContainer } from '../components/blocks/card-section/CardContainer';
import { Card } from '../components/blocks/card-section/Card';

const BecomeAStudentImage = '/images/become-a-student.webp';
const LightCurriculumImage = '/images/light-curriculum.webp';
const WiringImage = '/images/wiring-curriculum.webp';
const StudentImage = '/images/student-photo-1.webp';
const CurriculumImage1 = '/images/curriculum-image-1.webp';
const CurriculumImage4 = '/images/curriculum-image-4.webp';
const CardThree = '/images/student-fulltime.webp';

const pathwayStepCards = [
  {
    imageSrc: CurriculumImage1,
    imageAlt: 'Foundational training in BAS concepts.',
    contentTitle: '1. Foundational Training',
    content:
      'You start at the fundamentals - electricity, HVAC, networking, and controls logic - over fourteen weeks built for people new to the field.',
  },
  {
    imageSrc: CurriculumImage4,
    imageAlt: 'Onboarding with a partner employer.',
    contentTitle: '2. Employer Onboarding',
    content:
      'You onboard with one of our hiring partners, shadowing senior technicians on real systems. They see how you work; you see if the work fits.',
  },
  {
    imageSrc: CardThree,
    imageAlt: 'A Stacks+Joules graduate at full-time work.',
    contentTitle: '3. Full-Time Employment',
    content:
      'You step into a full-time role - BAS technician, controls installer, or junior programmer - on a team that already knows your training.',
  },
];

const careerRoleCards = [
  {
    headerText: 'BAS Technician',
    border: true,
    content: 'Install, maintain, and troubleshoot building control systems.',
  },
  {
    headerText: 'Controls Installer',
    border: true,
    content: 'Execute field installation and wiring of control devices.',
  },
  {
    headerText: 'Junior Programmer',
    border: true,
    content: 'Support system programming and commissioning work.',
  },
];

const careerGuideCards = [
  {
    headerText: 'What is building automation?',
    border: true,
    imageSrc: '/images/geo-what-is-bas.webp',
    imageAlt: 'A Stacks+Joules mentor and trainee in discussion.',
    content:
      'A clear breakdown of what a building automation system is, what the jobs look like, and how to learn it from zero.',
    buttonText: 'READ MORE',
    buttonLink: '/what-is-building-automation-how-to-learn-it',
  },
  {
    headerText: 'No experience? No problem.',
    border: true,
    imageSrc: '/images/geo-no-experience.webp',
    imageAlt: 'Hands-on work on a refrigeration unit during training.',
    content:
      'What it really takes to land your first BAS job — and why structured preparation beats prior experience.',
    buttonText: 'READ MORE',
    buttonLink: '/can-you-get-a-bas-job-with-no-experience',
  },
  {
    headerText: 'Salary & training path',
    border: true,
    imageSrc: '/images/geo-salary-path.webp',
    imageAlt: 'A Stacks+Joules graduating cohort celebrating together.',
    content:
      'What controls technicians earn and the step-by-step path from trainee to in-demand professional.',
    buttonText: 'READ MORE',
    buttonLink: '/controls-technician-salary-training-path',
  },
  {
    headerText: 'Getting into BAS in NYC',
    border: true,
    imageSrc: '/images/geo-bas-nyc.webp',
    imageAlt: 'Trainees inspecting building equipment with an infrared thermometer.',
    content:
      'The local roadmap: the training, certifications, and employers hiring building automation talent right now.',
    buttonText: 'READ MORE',
    buttonLink: '/how-to-get-into-building-automation-nyc',
  },
];
---

<Layout
  title="Train With Us | Stacks+Joules"
  description="Train with Stacks+Joules: 14 weeks of hands-on building automation training, an onboarding pipeline with a partner employer, and a path to a real career."
>
  <SectionHeader>Train With Us</SectionHeader>

  <Block variation="dark">
    <ImagePanel
      imageSrc={BecomeAStudentImage}
      imageAlt="A Stacks+Joules trainee."
      dropShadow
    />
    <TextPanel
      titleAs="h2"
      title="Your path into Building Automation starts here."
      description="No prior experience required. Fourteen weeks of hands-on training. A pipeline into a partner employer. A clear path into Building Automation. Everything you need to start a career in the technology that runs modern buildings."
      buttonText="TRAIN WITH US"
      buttonLink="#contact"
    />
  </Block>

  <Block variation="light" paddingY="0px" singleColumn>
    <CardContainer
      title="How It Works"
      description="Three stages, training to onboarding to full-time work - each built with the employers who'll hire you."
    >
      {pathwayStepCards.map(({ contentTitle, ...rest }) => (
        <Card key={contentTitle} contentTitle={contentTitle} {...rest} />
      ))}
    </CardContainer>
  </Block>

  <Block variation="dark">
    <TextPanel
      smallTitle="What you'll learn."
      description={"We start with fundamentals and build to job readiness:\n\n• Electricity, HVAC principles, and refrigeration cycle\n• Python coding and lighting controls (LCA certification)\n• EPA 608 certification\n• Low-voltage wiring and Niagara Workbench\n• Safety protocols, documentation, and professional communication\n\nYou'll get hands-on with the real hardware - controllers, sensors, dampers, and building management systems - diagnosing faults on running equipment, not simulations."}
    />
    <ImagePanel
      imageSrc={LightCurriculumImage}
      imageAlt="Trainees working with lighting controls."
      dropShadow
    />
  </Block>

  <Block variation="light" paddingY="0px" singleColumn>
    <CardContainer
      title="Careers You'll Qualify For"
      description="You graduate qualified for entry-level BAS roles. From there, the ladder goes up to technician → commissioning → engineering → energy management."
    >
      {careerRoleCards.map(({ headerText, ...rest }) => (
        <Card key={headerText} headerText={headerText} {...rest} />
      ))}
    </CardContainer>
  </Block>

  <Block variation="light" paddingY="0px" singleColumn>
    <CardContainer
      title="Is a career in building automation right for you?"
      description="New to BAS? These guides explain what the work actually is, what it pays, and how to break in — no experience required."
    >
      {careerGuideCards.map(({ headerText, ...rest }) => (
        <Card key={headerText} headerText={headerText} clampHeader {...rest} />
      ))}
    </CardContainer>
  </Block>

  <Block variation="dark">
    <ImagePanel
      imageSrc={WiringImage}
      imageAlt="A trainee working on a building automation panel."
      dropShadow
    />
    <TextPanel
      smallTitle="From trainee to trainer."
      description={"Ahmed walked in with no building automation experience. TEC Systems hired him three months after graduation. Three years later, he was a Senior Commissioning Technician. Now he trains the next cohort coming through TEC.\n\nAdvancement isn't a single ladder. Technicians specialize in commissioning, move into engineering, or focus on energy management and analytics. Each path builds on the foundation you got at Stacks+Joules."}
    />
  </Block>

  <Block variation="dark">
    <TextPanel
      caption="Ready to apply?"
      smallTitle="Fourteen weeks. Real systems. A real career."
      description="Three cohorts a year. 25 students per class. Get in touch and we'll walk you through eligibility, what to expect, and the next start date."
      buttonText="GET IN TOUCH"
      buttonLink="#contact"
    />
    <ImagePanel
      imageSrc={StudentImage}
      imageAlt="A Stacks+Joules graduate."
      dropShadow
    />
  </Block>
</Layout>
