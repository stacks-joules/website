---
import Layout from '../layouts/Layout.astro';
import { SectionHeader } from '../components/layout/SectionHeader';
import { TextPanel } from '../components/blocks/panels/TextPanel';
import { Block } from '../components/blocks/block/Block';
import { ImagePanel } from '../components/blocks/panels/ImagePanel';
import { MarkupPanel } from '../components/blocks/panels/MarkupPanel';
import { CardContainer } from '../components/blocks/card-section/CardContainer';
import { Card } from '../components/blocks/card-section/Card';
const BecomeAStudentImage = '/images/become-a-student.png';

const careerCards = [
  {
    headerText: '↳ What is building automation?',
    border: true,
    imageSrc: '/images/card-1.png',
    imageAlt: 'What is building automation',
    content:
      'A clear breakdown of what a building automation system is, what the jobs actually look like, and how to learn it from zero.',
    buttonText: 'READ MORE',
    buttonLink: '/what-is-building-automation-how-to-learn-it',
  },
  {
    headerText: '↳ No experience? No problem.',
    border: true,
    imageSrc: '/images/card-2.png',
    imageAlt: 'Can you get a BAS job with no experience',
    content:
      'What it really takes to land your first BAS job — and why structured preparation beats prior experience.',
    buttonText: 'READ MORE',
    buttonLink: '/can-you-get-a-bas-job-with-no-experience',
  },
  {
    headerText: '↳ Salary & training path',
    border: true,
    imageSrc: '/images/card-3.png',
    imageAlt: 'Controls technician salary and training path',
    content:
      'What controls technicians earn and the step-by-step path from trainee to in-demand professional.',
    buttonText: 'READ MORE',
    buttonLink: '/controls-technician-salary-training-path',
  },
  {
    headerText: '↳ Getting into BAS in NYC',
    border: true,
    imageSrc: '/images/student-photo-1.png',
    imageAlt: 'How to get into building automation in NYC',
    content:
      'The local roadmap: the training, certifications, and employers hiring building automation talent right now.',
    buttonText: 'READ MORE',
    buttonLink: '/how-to-get-into-building-automation-nyc',
  },
];
---

<Layout title="Become a Student | Stacks+Joules">
  <SectionHeader>Become a Student</SectionHeader>
  <Block variation="dark">
    <ImagePanel
      imageSrc={BecomeAStudentImage}
      imageAlt="Become a Student"
      dropShadow
    />
    <MarkupPanel>
      <p>
        <b>Stacks+Joules</b> is a 501c3 nonprofit (EIN 82-2358571)
        project-based learning program in computer programming and wireless
        network management. Our specialized curriculum engages young
        peoples' creativity to supercharge their strengths as learners and
        get them on the fast-track to valuable technology skills—regardless
        of prior experience or training.
      </p>
    </MarkupPanel>
  </Block>
  <Block variation="light">
    <TextPanel
      caption="Co-Founder and Chief Technology Officer"
      smallTitle="Jonathan Spooner"
      description="Jonathan brings a trove of experience in technology, innovation and marketing to the Stacks + Joules team. Having led innovation teams at Intersection (a division of Alphabet) and launching multiple high-tech businesses he has a wide breadth of knowledge. His entrepreneurial passion has led him to plan, budget, oversee and lead all sizes of businesses across the span of his career. A lifelong DJ having played multiple gigs around the globe he also co-founded the internet's first DJ mix site. Jonathan speaks frequently on emerging technology innovation, and his insight has been featured in the New York Times, Ad Age, Fast Company, The Motley Fool and the Wall Street Journal, among others. "
    />
    <ImagePanel
      imageSrc={BecomeAStudentImage}
      imageAlt="Picture of Jonathan Spooner"
      dropShadow
    />
  </Block>
  <Block variation="light" singleColumn>
    <CardContainer
      title="↳ Is a career in building automation right for you?"
      description="New to BAS? These guides explain what the work actually is, what it pays, and how to break in — no experience required."
    >
      {careerCards.map((card) => (
        <Card key={card.headerText} {...card} />
      ))}
    </CardContainer>
  </Block>
</Layout>
